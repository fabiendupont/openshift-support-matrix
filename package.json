{
  "name": "openshift-support-matrix",
  "version": "0.1.0",
  "description": "Retrieve supported Red Hat OpenShift Container Platform versions with extended metadata",
  "main": "lib/core.js",
  "bin": {
    "openshift-support-matrix": "dist/cli/index.js"
  },
  "files": [
    "dist/cli/"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build lib/action.js -o dist/action --source-map --license licenses.txt && ncc build lib/cli.js -o dist/cli --source-map",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabiendupont/openshift-support-matrix.git"
  },
  "keywords": [
    "openshift",
    "ocp",
    "matrix",
    "ci",
    "github-actions",
    "gitlab-ci"
  ],
  "author": "Fabien Dupont",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "overrides": {
    "undici": "^7.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@typescript-eslint/parser": "^8.61.0",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
